<?xml version="1.0"?>
<robot name="hexapod_control" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Minimal URDF for controller_manager + robot_state_publisher.
       This is NOT intended to replace your full CAD-derived robot description.
       It only provides joint/frame names that match the MuJoCo model. -->

  <link name="base_link"/>
  <link name="camera_link"/>
  <link name="camera_optical_frame"/>
  <link name="imu_link"/>

  <joint name="camera_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.26 0.0 0.57" rpy="0 0 0"/>
  </joint>

  <!-- ROS optical frame: +X right, +Y down, +Z forward -->
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
  </joint>

  <joint name="imu_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.18 0.0 0.52" rpy="0 0 0"/>
  </joint>

  <link name="fl_link"/>
  <link name="fr_link"/>
  <link name="lm_link"/>
  <link name="rm_link"/>
  <link name="bl_link"/>
  <link name="br_link"/>

  <joint name="fl_rightdown" type="continuous">
    <parent link="base_link"/>
    <child link="fl_link"/>
    <origin xyz="0.20 0.25 0.00" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <joint name="fr_rightdown" type="continuous">
    <parent link="base_link"/>
    <child link="fr_link"/>
    <origin xyz="0.20 -0.25 0.00" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <joint name="lm_rightdown" type="continuous">
    <parent link="base_link"/>
    <child link="lm_link"/>
    <origin xyz="0.00 0.28 0.00" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <joint name="rm_rightdown" type="continuous">
    <parent link="base_link"/>
    <child link="rm_link"/>
    <origin xyz="0.00 -0.28 0.00" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <joint name="bl_rightdown" type="continuous">
    <parent link="base_link"/>
    <child link="bl_link"/>
    <origin xyz="-0.20 0.25 0.00" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <joint name="br_rightdown" type="continuous">
    <parent link="base_link"/>
    <child link="br_link"/>
    <origin xyz="-0.20 -0.25 0.00" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <ros2_control name="hexapod_topic_system" type="system">
    <hardware>
      <plugin>joint_state_topic_hardware_interface/JointStateTopicSystem</plugin>
      <param name="joint_commands_topic">/topic_based_joint_commands</param>
      <param name="joint_states_topic">/topic_based_joint_states</param>
      <param name="trigger_joint_command_threshold">-1</param>
      <param name="sum_wrapped_joint_states">false</param>
    </hardware>

    <joint name="fl_rightdown">
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="fr_rightdown">
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lm_rightdown">
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rm_rightdown">
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="bl_rightdown">
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="br_rightdown">
      <command_interface name="velocity"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
</robot>
