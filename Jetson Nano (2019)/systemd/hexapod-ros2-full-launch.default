# Host-side configuration for /etc/systemd/system/hexapod-ros2-full-launch.service
# The container is expected to already auto-start at boot.

HEXAPOD_CONTAINER_NAME=jazzy
HEXAPOD_MICROROS_AGENT_CONTAINER=microros_agent
HEXAPOD_WAIT_FOR_MICROROS_AGENT=true
HEXAPOD_ROS_SETUP=/opt/ros/jazzy/setup.bash
HEXAPOD_WS_SETUP=/ros2_ws/install/setup.bash
HEXAPOD_MAP_DIR=/ros2_ws/maps
HEXAPOD_OPERATOR_URL=http://192.168.50.1:8080/
HEXAPOD_OPERATOR_HTTP_PORT=8080
HEXAPOD_LCD_I2C_DEVICE=/dev/i2c-1
HEXAPOD_LCD_I2C_ADDRESS=39
HEXAPOD_LCD_STATIC_URL_ONLY=true
HEXAPOD_NAV2_START_DELAY_SEC=10.0
HEXAPOD_START_ORBSLAM_SLAMTOOLBOX=true
HEXAPOD_START_HARDWARE_STACK=true
HEXAPOD_START_TRIPOD_CONTROLLER=true
HEXAPOD_START_OPERATOR_INTERFACE=true
HEXAPOD_START_LCD_STATUS=true
HEXAPOD_START_MERGED_VISUALIZATION=false
HEXAPOD_OPERATOR_DEFAULT_MODE=estop
HEXAPOD_OPERATOR_LATCH_TELEOP_COMMANDS=true
HEXAPOD_OPERATOR_KEYBOARD_LINEAR_MPS=0.50
HEXAPOD_OPERATOR_KEYBOARD_ANGULAR_RADPS=0.50
HEXAPOD_OPERATOR_MAX_LINEAR_MPS=3.00
HEXAPOD_OPERATOR_MAX_ANGULAR_RADPS=3.00
HEXAPOD_OPERATOR_WAYPOINT_MAX_LINEAR_MPS=0.50
HEXAPOD_OPERATOR_WAYPOINT_MAX_ANGULAR_RADPS=0.50
HEXAPOD_START_IMU_UDP_EXPORT=false
HEXAPOD_OPERATOR_HOST_CONTROL_BASE_URL=http://127.0.0.1:18080
HEXAPOD_OPERATOR_MAPPING_UPDATES_ENABLED_DEFAULT=true
HEXAPOD_ORBSLAM_SCAN_PUBLISH_DECIMATION=3

# Runtime cleanup / offline-safe DDS settings. No package installation required.
HEXAPOD_DISABLE_FASTDDS_SHM=true
HEXAPOD_CLEAN_STALE_ROS=true
